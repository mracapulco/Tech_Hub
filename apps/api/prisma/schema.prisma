generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
  CLIENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String?  @unique
  name      String
  lastName  String?
  password  String
  avatarUrl String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserCompanyMembership[]
}

model Company {
  id        String   @id @default(uuid())
  cnpj      String?  @unique
  name      String
  fantasyName String?
  address   String?
  city      String?
  state     String?
  zipcode   String?
  phone     String?
  logoUrl   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserCompanyMembership[]
  maturityAssessments MaturityAssessment[]
  sites      Site[]
  vrfs       Vrf[]
  subnets    IpSubnet[]
  firewallLicenses FirewallLicense[]
  backupRepositories BackupRepository[]
  backupProxies BackupProxy[]
  backupCores BackupCore[]
  backupJobs BackupJob[]
  backupSummaries BackupSummaryMonthly[]
  adFsProjects AdFsProject[]
}

model UserCompanyMembership {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

// Registro de testes de maturidade de segurança
model MaturityAssessment {
  id         String   @id @default(uuid())
  date       String
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  answers    Json?
  groupScores Json?
  totalScore Int?
  maxScore   Int?
  createdAt  DateTime @default(now())

  // Relação 1:1 com análise por IA (quando existir)
  analysis   MaturityAnalysis?
}

// Catálogo global de tipos de dispositivo (ex.: Nobreak, Servidor, Rack, Switch)
model DeviceType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brands      BrandDeviceType[]
  devices     Device[]
}

// Catálogo global de marcas (ex.: APC, Dell, HP)
model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  logoUrl     String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deviceTypes BrandDeviceType[]
  devices     Device[]
}

// Relação N:N entre Marcas e Tipos de Dispositivo
model BrandDeviceType {
  id            String     @id @default(uuid())
  brand         Brand      @relation(fields: [brandId], references: [id])
  brandId       String
  deviceType    DeviceType @relation(fields: [deviceTypeId], references: [id])
  deviceTypeId  String
  createdAt     DateTime   @default(now())

  @@unique([brandId, deviceTypeId])
}

// Inventário de dispositivos
model Device {
  id           String     @id @default(uuid())
  deviceType   DeviceType @relation(fields: [deviceTypeId], references: [id])
  deviceTypeId String
  brand        Brand      @relation(fields: [brandId], references: [id])
  brandId      String
  model        String
  slug         String?
  uHeight      Int?
  isFullDepth  Boolean    @default(false)
  frontImage   Boolean    @default(false)
  rearImage    Boolean    @default(false)
  weight       Float?
  weightUnit   String?    @default("kg")
  airflow      String?
  consolePorts Json?
  interfaces   Json?
  moduleBays   Json?
  status       String     @default("ACTIVE")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Configurações globais (ex.: chaves de integração) com valor criptografado
model Setting {
  id         String   @id @default(uuid())
  key        String   @unique
  valueEnc   String
  updatedBy  String?
  updatedAt  DateTime @default(now()) @updatedAt
}

// Resultado de análise por IA atrelado a um teste de maturidade
model MaturityAnalysis {
  id            String             @id @default(uuid())
  assessment    MaturityAssessment @relation(fields: [assessmentId], references: [id])
  assessmentId  String             @unique
  content       Json
  provider      String?
  model         String?
  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

enum IpAddressStatus {
  ASSIGNED
  RESERVED
}

model Vrf {
  id        String   @id @default(uuid())
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets   IpSubnet[]

  @@unique([companyId, name])
}

model Site {
  id        String   @id @default(uuid())
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  name      String
  city      String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vlans     Vlan[]
  subnets   IpSubnet[]
  firewallLicenses FirewallLicense[]
  backupRepositories BackupRepository[]
  backupProxies BackupProxy[]

  @@unique([companyId, name])
}

model Vlan {
  id        String   @id @default(uuid())
  site      Site     @relation(fields: [siteId], references: [id])
  siteId    String
  number    Int
  name      String
  purpose   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets   IpSubnet[]

  @@unique([siteId, number])
}

model FirewallLicense {
  id          String   @id @default(uuid())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  site        Site?    @relation(fields: [siteId], references: [id])
  siteId      String?
  ipAddress   IpAddress? @relation(name: "IpAddressFirewallLicenses", fields: [ipAddressId], references: [id])
  ipAddressId String?
  vendor      String
  model       String
  serial      String
  licenseName String
  licenseNumber String?
  licenseFileUrl String?
  expiresAt   DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([siteId])
  @@index([expiresAt])
  @@index([ipAddressId])
}

model IpSubnet {
  id          String   @id @default(uuid())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  site        Site?    @relation(fields: [siteId], references: [id])
  siteId      String?
  vrf         Vrf?     @relation(fields: [vrfId], references: [id])
  vrfId       String?
  vlan        Vlan?    @relation(fields: [vlanId], references: [id])
  vlanId      String?
  name        String
  cidr        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addresses   IpAddress[]

  @@index([companyId])
  @@index([siteId])
  @@index([vrfId])
  @@index([vlanId])
}

model IpAddress {
  id         String          @id @default(uuid())
  subnet     IpSubnet        @relation(fields: [subnetId], references: [id])
  subnetId   String
  address    String
  hostname   String?
  status     IpAddressStatus @default(ASSIGNED)
  assignedTo String?
  createdAt  DateTime        @default(now())

  firewallLicenses FirewallLicense[] @relation(name: "IpAddressFirewallLicenses")

  @@unique([subnetId, address])
}

// Backup
enum BackupRunStatus {
  SUCCESS
  WARN
  FAIL
}

model BackupRepository {
  id           String   @id @default(uuid())
  company      Company  @relation(fields: [companyId], references: [id])
  companyId    String
  site         Site?    @relation(fields: [siteId], references: [id])
  siteId       String?
  name         String
  type         String
  capacityGB   Int
  usedGB       Int      @default(0)
  retentionPolicy String?
  compressionRatio Float?
  dedupeRatio     Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([siteId])

  jobs BackupJob[]
}

model BackupProxy {
  id         String   @id @default(uuid())
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  site       Site?    @relation(fields: [siteId], references: [id])
  siteId     String?
  hostname   String
  cores      Int
  memoryGB   Int
  throughputMBps Int?
  concurrency Int?
  transportMode String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([siteId])

  jobs BackupJob[]
}

model BackupCore {
  id          String   @id @default(uuid())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  hostname    String
  version     String?
  license     String?
  jobsCount   Int       @default(0)
  repositoriesCount Int @default(0)
  proxiesCount Int      @default(0)
  healthStatus String?  @default("UNKNOWN")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
}

model BackupJob {
  id            String   @id @default(uuid())
  company       Company  @relation(fields: [companyId], references: [id])
  companyId     String
  name          String
  type          String
  schedule      String?
  retentionPolicy String?
  repository    BackupRepository @relation(fields: [repositoryId], references: [id])
  repositoryId  String
  proxy         BackupProxy?     @relation(fields: [proxyId], references: [id])
  proxyId       String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  runs          BackupRun[]

  @@index([companyId])
  @@index([repositoryId])
  @@index([proxyId])
}

model BackupRun {
  id            String          @id @default(uuid())
  job           BackupJob       @relation(fields: [jobId], references: [id])
  jobId         String
  startAt       DateTime
  endAt         DateTime?
  status        BackupRunStatus
  processedGB   Float           @default(0)
  transferredGB Float           @default(0)
  avgSpeedMBps  Float?
  bottleneck    String?
  errors        String?
  restorePointsCreated Int?     @default(0)
  createdAt     DateTime        @default(now())

  @@index([jobId])
  @@index([status])
}

model BackupSummaryMonthly {
  id           String   @id @default(uuid())
  company      Company  @relation(fields: [companyId], references: [id])
  companyId    String
  month        String
  jobsTotal    Int      @default(0)
  successRate  Float    @default(0)
  failures     Int      @default(0)
  avgDurationMinutes Float @default(0)
  storageGrowthGB Float  @default(0)
  topIssues    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, month])
}

enum AdFsNodeType {
  ROOT
  UNIT
  SECTOR
  SUBSECTOR
  FOLDER
}

enum AdFsGroupKind {
  GF
  GA
}

enum AdFsPermissionProfile {
  L
  LG
  LE
  FULL
}

enum AdFsProjectStatus {
  DRAFT
  APPROVED
  IMPLEMENTED
}

model AdFsProject {
  id          String             @id @default(uuid())
  company     Company            @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  description String?
  domainName  String?
  rootOuName  String?
  rootPath    String             @default("D:\\FILESERVER")
  status      AdFsProjectStatus  @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  orgNodes    AdFsOrgNode[]
  ouNodes     AdFsOuNode[]
  groups      AdFsGroup[]
  users       AdFsUserPlan[]
  folders     AdFsFolderNode[]
  gpos        AdFsGpoPlan[]

  @@index([companyId])
}

model AdFsOrgNode {
  id          String       @id @default(uuid())
  project     AdFsProject  @relation(fields: [projectId], references: [id])
  projectId   String
  parent      AdFsOrgNode? @relation("AdFsOrgTree", fields: [parentId], references: [id])
  parentId    String?
  children    AdFsOrgNode[] @relation("AdFsOrgTree")
  type        AdFsNodeType
  name        String
  code        String?
  description String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       AdFsUserPlan[]
  folders     AdFsFolderNode[]
  groups      AdFsGroup[]

  @@index([projectId])
  @@index([parentId])
}

model AdFsOuNode {
  id          String       @id @default(uuid())
  project     AdFsProject  @relation(fields: [projectId], references: [id])
  projectId   String
  parent      AdFsOuNode?  @relation("AdFsOuTree", fields: [parentId], references: [id])
  parentId    String?
  children    AdFsOuNode[] @relation("AdFsOuTree")
  name        String
  distinguishedName String?
  description String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       AdFsUserPlan[]
  gpos        AdFsGpoPlan[]

  @@index([projectId])
  @@index([parentId])
}

model AdFsGroup {
  id          String         @id @default(uuid())
  project     AdFsProject    @relation(fields: [projectId], references: [id])
  projectId   String
  kind        AdFsGroupKind
  name        String
  description String?
  permission  AdFsPermissionProfile?
  orgNode     AdFsOrgNode?   @relation(fields: [orgNodeId], references: [id])
  orgNodeId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members     AdFsUserPlan[] @relation("AdFsGroupMembers")
  folderPermissions AdFsFolderPermission[]

  @@index([projectId])
  @@index([orgNodeId])
}

model AdFsUserPlan {
  id          String       @id @default(uuid())
  project     AdFsProject  @relation(fields: [projectId], references: [id])
  projectId   String
  orgNode     AdFsOrgNode? @relation(fields: [orgNodeId], references: [id])
  orgNodeId   String?
  ouNode      AdFsOuNode?  @relation(fields: [ouNodeId], references: [id])
  ouNodeId    String?
  fullName    String
  firstName   String
  lastName    String?
  username    String
  email       String?
  title       String?
  enabled     Boolean      @default(true)
  initialPassword String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  groups      AdFsGroup[]  @relation("AdFsGroupMembers")

  @@index([projectId])
  @@index([orgNodeId])
  @@index([ouNodeId])
}

model AdFsFolderNode {
  id          String       @id @default(uuid())
  project     AdFsProject  @relation(fields: [projectId], references: [id])
  projectId   String
  parent      AdFsFolderNode? @relation("AdFsFolderTree", fields: [parentId], references: [id])
  parentId    String?
  children    AdFsFolderNode[] @relation("AdFsFolderTree")
  orgNode     AdFsOrgNode? @relation(fields: [orgNodeId], references: [id])
  orgNodeId   String?
  type        AdFsNodeType @default(FOLDER)
  name        String
  pathOverride String?
  disableInheritance Boolean @default(true)
  appliesTo   String?      @default("ThisFolderOnly")
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions  AdFsFolderPermission[]

  @@index([projectId])
  @@index([parentId])
  @@index([orgNodeId])
}

model AdFsFolderPermission {
  id           String                @id @default(uuid())
  folderNode   AdFsFolderNode        @relation(fields: [folderNodeId], references: [id])
  folderNodeId String
  group        AdFsGroup             @relation(fields: [groupId], references: [id])
  groupId      String
  permission   AdFsPermissionProfile
  appliesTo    String                @default("ThisFolderSubfoldersAndFiles")
  deny         Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([folderNodeId])
  @@index([groupId])
}

model AdFsGpoPlan {
  id          String       @id @default(uuid())
  project     AdFsProject  @relation(fields: [projectId], references: [id])
  projectId   String
  ouNode      AdFsOuNode?  @relation(fields: [ouNodeId], references: [id])
  ouNodeId    String?
  name        String
  description String?
  category    String?
  linkEnabled Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([ouNodeId])
}
